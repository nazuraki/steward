# GitHub authentication — set ONE of the following two options:

# Option A: PAT or GitHub Actions GITHUB_TOKEN
GITHUB_TOKEN=                        # repo scope required; workflow scope for org repos

# Option B: GitHub App (takes precedence over GITHUB_TOKEN if all three are set)
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=            # PEM contents; use \n for embedded newlines
# GITHUB_APP_INSTALLATION_ID=        # found at: github.com/apps/{app-slug}/installations

ANTHROPIC_API_KEY=
GITHUB_REPO=owner/repo               # e.g. acme/my-service

# Agent identity
GITHUB_BOT_USERNAME=                 # GitHub username of the bot account
GIT_USER_NAME=                       # git commit author name (e.g. "My Bot")
GIT_USER_EMAIL=                      # GitHub noreply: ID+username@users.noreply.github.com

# Docker / runtime environment
WORK_DIR=/tmp/repo                   # fresh clone target each run; wiped at start of Phase 0
LOG_DIR=/var/log/steward             # mount a volume here to persist logs

# Network (default off — set true for repos that need network during build/test)
ALLOW_NETWORK=false

# Invocation-time toggles
DRY_RUN=false

# Limit overrides (all optional — defaults in steward.json or built-in defaults apply)
# MAX_TOOL_ITERATIONS=25
# MAX_PR_FIX_ITERATIONS=10
# MAX_PLAN_RETRIES=2
# MAX_RUNTIME_SECONDS=600
# MAX_COMMANDS=20
# MAX_FILE_WRITES=30
# CMD_OUTPUT_MAX_TOKENS=2000
# MAX_TOKENS_PER_RUN=
# MAX_ISSUE_FAILURES=3
# CONSECUTIVE_FAILURE_THRESHOLD=3
# RATE_LIMIT_THRESHOLD=100

# Access control overrides (comma-separated, optional)
# AGENT_COMMENT_ALLOWLIST=user1,user2
# AGENT_COMMENT_SKIPLIST=dependabot[bot],github-actions[bot]
# REQUIRE_ISSUE_ALLOWLIST=true
# REQUIRED_LABELS=bug,enhancement,feature,documentation,refactor,chore
# PRIORITY_LABELS=priority,nice to have
# COMMAND_ALLOWLIST=npm test,npm run lint
